global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets:
          - "localhost:9090"

  - job_name: "node_exporter"
    static_configs:
      - targets:
          - "{{ web_server_ip }}:9100"
          - "{{ app_server_ip }}:9100"
          - "{{ db_server_ip }}:9100"
          - "{{ monitoring_server_ip }}:9100"